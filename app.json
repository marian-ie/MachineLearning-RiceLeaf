{
  "expo": {
    "name": "Rice Stress Lab",
    "slug": "riceapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.jpg",
    "splash": {
      "image": "./assets/logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#F4F6F4"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "assets": [
      "./assets/rice_model.tflite"
    ],
    "plugins": [
      "expo-sqlite",
      "expo-asset"
    ],
    "android": {
      "package": "com.riceapp.stressdetector",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "04b4bdab-63bc-4eb7-b5cd-e0ba0d6d9023"
      }
    }
  }
}
